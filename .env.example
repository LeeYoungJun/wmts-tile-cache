PORT=3000
LOG_LEVEL=info
CONFIG_PATH=./config.yaml

# Upstream API keys (referenced in config.yaml as ${VAR_NAME})
# UPSTREAM_API_KEY=your-api-key-here

# Host path for persistent cache storage
CACHE_HOST_DIR=../wmts-tile-cache-data

# Host path for config file bind mount
CONFIG_HOST_PATH=./config.yaml
